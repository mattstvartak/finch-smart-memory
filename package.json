{
  "name": "@onenomad/finch-smart-memory",
  "version": "1.0.7",
  "description": "Smart memory plugin for OpenClaw — LLM-powered extraction, hybrid ANN search, tier lifecycle, spreading activation, procedural rules, WAL, Mem0, and session-state hot RAM.",
  "type": "module",
  "main": "dist/plugin.js",
  "openclaw": {
    "extensions": ["./dist/plugin.js"],
    "compat": {
      "pluginApi": ">=2026.3.0",
      "gatewayApi": ">=2026.3.0"
    },
    "build": {
      "openclawVersion": "2026.3.24",
      "sdkVersion": "2026.3.24"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "rm -rf dist && tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "@sinclair/typebox": "^0.34.49",
    "mem0ai": "^2.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
